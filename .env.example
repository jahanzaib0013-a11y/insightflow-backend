# Copy to .env and fill in. Every value here is required for full functionality;
# see app/core/config.py for defaults and what happens when values are missing.

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=

# Google OAuth (console.cloud.google.com/apis/credentials)
# Redirect URI to register: http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (github.com -> Settings -> Developer settings -> OAuth Apps)
# Callback URL to register: http://127.0.0.1:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email via Gmail SMTP (myaccount.google.com/apppasswords).
# Leave SMTP_USER empty to print emails to the server log instead of sending.
SMTP_USER=
SMTP_PASSWORD=

FRONTEND_URL=http://localhost:3000
